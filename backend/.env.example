FLASK_ENV=development
SECRET_KEY=change-this-secret-key
JWT_SECRET_KEY=change-this-jwt-secret

# Prefer DATABASE_URL in production. Example:
# DATABASE_URL=mysql+pymysql://jewellery_user:strong_password@localhost:3306/jewellery_shop
DB_HOST=localhost
DB_PORT=3306
DB_NAME=jewellery_shop
DB_USER=root
DB_PASSWORD=

FRONTEND_ORIGIN=http://localhost:5173
UPLOAD_FOLDER=uploads/products
LOW_STOCK_THRESHOLD=5

# Optional live gold-rate provider. If absent, the API returns a configurable fallback.
GOLD_RATE_API_URL=
GOLD_RATE_API_KEY=
FALLBACK_GOLD_RATE_24K=6450

# Restore executes SQL and should stay disabled except for trusted maintenance windows.
ENABLE_RESTORE=false
